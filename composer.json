{
    "name": "jetty/client",
    "description": "Jetty PHP client for the tunnel API (list, delete, share + edge WebSocket agent + heartbeats). Publish this tree as the jetty-client repository; require with Composer: jetty/client.",
    "type": "library",
    "license": "MIT",
    "keywords": ["jetty", "tunnel", "cli", "api"],
    "version": "0.1.16",
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "composer-runtime-api": "^2.2",
        "amphp/websocket-client": "^2.0"
    },
    "suggest": {
        "ext-openssl": "For `wss://` edge WebSocket URLs (`jetty share`)",
        "ext-pcntl": "For clean Ctrl+C handling when running `jetty share`",
        "ext-zlib": "Required to run the gzipped PHAR build (`composer run build-phar`)"
    },
    "bin": [
        "bin/jetty"
    ],
    "autoload": {
        "psr-4": {
            "JettyCli\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "require-dev": {
        "humbug/box": "^4.6",
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "build-phar": "box compile --no-interaction",
        "test": "phpunit"
    },
    "autoload-dev": {
        "psr-4": {
            "JettyCli\\Tests\\": "tests/"
        }
    },
    "replace": {
        "jetty/php-cli": "*"
    }
}
