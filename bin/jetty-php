#!/usr/bin/env php
<?php

declare(strict_types=1);

$autoload = dirname(__DIR__).'/vendor/autoload.php';
if (! is_file($autoload)) {
    fwrite(STDERR, "Run `composer install` in the jetty-client directory, or install with: composer require jetty/client\n");
    exit(1);
}

require $autoload;

exit((new JettyCli\Application)->run($argv));
